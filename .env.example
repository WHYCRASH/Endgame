# =========================================================================
# LLM API KEYS — fill these in
# =========================================================================

# Anthropic (native integration in Open WebUI)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter (used as the OpenAI-compatible endpoint)
OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Open WebUI
# Auto-generated on first boot if WEBUI_SECRET_KEY is blank, but for
# container recreate stability you should set a persistent value:
#   openssl rand -hex 32
WEBUI_SECRET_KEY=

# =========================================================================
# MetaMCP
# =========================================================================

# Generate at: https://docs.metamcp.com or set any random string
METAMCP_API_KEY=sk_mt_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MetaMCP's own postgres
METAMCP_POSTGRES_PASSWORD=changeme_metamcp_pg

# =========================================================================
# axum-embed (usually no edits needed; defaults are sane)
# =========================================================================

# Embedding model — must match a fastembed-rs EmbeddingModel variant
EMBED_MODEL=intfloat/multilingual-e5-small

# Rerank model — must match a fastembed-rs RerankerModel model_code
RERANK_MODEL=BAAI/bge-reranker-base

# Cache dir for downloaded ONNX models (volume-mounted in compose)
FASTEMBED_CACHE_DIR=/data/.fastembed_cache

# Listen address (matches the port in docker-compose)
LISTEN_ADDR=0.0.0.0:8080

# Optional: cap ONNX intra-op threads. Defaults to all cores.
# On a laptop you may want to set this to ~4 to keep the system responsive.
# INTRA_THREADS=4

# =========================================================================
# Open WebUI — LLM wiring (no edits needed if using the defaults above)
# =========================================================================

# OpenRouter as the OpenAI-compatible backend
OPENAI_API_BASE_URL=https://openrouter.ai/api/v1

# =========================================================================
# Open WebUI — Embeddings -> axum-embed
# =========================================================================

RAG_EMBEDDING_ENGINE=openai
RAG_EMBEDDING_MODEL=intfloat/multilingual-e5-small
RAG_OPENAI_API_BASE_URL=http://axum-embed:8080/v1
RAG_OPENAI_API_KEY=dummy

# e5-small requires query/passage prefixes. Open WebUI prepends these before
# calling axum-embed, so axum-embed itself stays prefix-agnostic.
RAG_EMBEDDING_QUERY_PREFIX=query: 
RAG_EMBEDDING_CONTENT_PREFIX=passage: 

# =========================================================================
# Open WebUI — Reranking -> axum-embed
# =========================================================================

RAG_RERANKING_ENGINE=external
RAG_RERANKING_MODEL=BAAI/bge-reranker-base
# NOTE: Open WebUI does NOT append /v1/rerank for you — give the full URL.
RAG_EXTERNAL_RERANKER_URL=http://axum-embed:8080/v1/rerank
RAG_EXTERNAL_RERANKER_API_KEY=dummy

# =========================================================================
# Open WebUI — Hybrid search + retrieval tuning
# =========================================================================

ENABLE_RAG_HYBRID_SEARCH=true
RAG_TOP_K=20
RAG_TOP_K_RERANKER=4
RAG_RELEVANCE_THRESHOLD=0.0

# =========================================================================
# Open WebUI — Vector DB (Qdrant)
# =========================================================================

VECTOR_DB=qdrant
QDRANT_URI=http://qdrant:6333

# =========================================================================
# Open WebUI — MetaMCP as a tool server
# =========================================================================

ENABLE_DIRECT_CONNECTIONS=true
TOOL_SERVER_CONNECTIONS=[{"type":"openapi","url":"http://metamcp:12008","path":"openapi.json","auth_type":"bearer","key":"${METAMCP_API_KEY}","config":{"enable":true},"info":{"name":"MetaMCP","description":"MCP aggregator"}}]
